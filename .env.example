# Configuración del despliegue de OSRM (copiar a .env y ajustar si hace falta).

# Fuente de datos OSM (Geofabrik). Es el país completo; se recorta con BBOX.
GEOFABRIK_URL=https://download.geofabrik.de/north-america/mexico-latest.osm.pbf

# Recorte: LEFT,BOTTOM,RIGHT,TOP = minLon,minLat,maxLon,maxLat.
# Default cubre Chiapas (Suchiapa, Tuxtla y alrededores). Ampliar si crece la operación.
BBOX=-94.2,14.5,-90.3,17.99

# Perfil de ruteo OSRM. Los mototaxis circulan como autos -> car.
PROFILE=/opt/car.lua

# Nombre base de los archivos .osrm dentro del volumen.
OSRM_NAME=chiapas

# Pon true UNA vez para reconstruir el mapa con datos nuevos; luego regrésalo a false.
FORCE_REBUILD=false

# Conservar el pbf de México (~1.5 GB) tras preprocesar. Default false (se borra para ahorrar disco).
KEEP_SOURCE_PBF=false
